    },
    "/api/program-manager/benefits/{id}/approve": {
      "put": {
        "tags": [
          "Benefit Approval"
        ],
        "summary": "Approve a benefit — set amount and notify citizen",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "amount",
            "in": "query",
            "schema": {
              "type": "number",
              "format": "double"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
