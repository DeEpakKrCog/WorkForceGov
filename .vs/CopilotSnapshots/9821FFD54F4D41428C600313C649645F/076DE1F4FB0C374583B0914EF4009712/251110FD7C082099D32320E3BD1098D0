using Swashbuckle.AspNetCore.SwaggerGen;

namespace WorkForceGovProject.Extensions
{
    /// <summary>
    /// Extension to add Bearer token security to Swagger/OpenAPI
    /// </summary>
    public static class SwaggerExtensions
    {
        public static void AddSwaggerGenWithBearerToken(this IServiceCollection services)
        {
            services.AddSwaggerGen(c =>
            {
                c.SwaggerDoc("v1", new()
                {
                    Title = "WorkForceGov — Citizen API",
                    Version = "v1",
                    Description = "Citizen Services API with JWT Bearer Token Authentication"
                });

                c.EnableAnnotations();

                // Add Bearer token security scheme for better Swagger UI
                c.AddSecurityDefinition("bearer", new()
                {
                    Type = "http",
                    Scheme = "bearer",
                    BearerFormat = "JWT",
                    Description = "JWT Authorization header using the Bearer scheme. Example: \"Authorization: Bearer {token}\""
                });

                c.AddSecurityRequirement(new()
                {
                    {
                        new()
                        {
                            Reference = new() { Type = 3, Id = "bearer" }
                        },
                        new List<string>()
                    }
                });
            });
        }
    }
}
