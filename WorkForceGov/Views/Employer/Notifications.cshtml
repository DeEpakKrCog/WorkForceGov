@model IEnumerable<Notification>
@{ ViewData["Title"] = "Notifications"; }
<div class="page-header"><h1>Notifications</h1></div>
<div class="table-card">
@foreach(var n in Model){<div style="padding:16px 24px;border-bottom:1px solid #f1f5f9;"><div style="font-size:.875rem;">@n.Message</div><div style="font-size:.75rem;color:#94a3b8;margin-top:2px;">@n.CreatedDate.ToString("MMM dd, yyyy")</div></div>}
@if(!Model.Any()){<div class="text-center text-muted py-5">No notifications.</div>}
</div>
