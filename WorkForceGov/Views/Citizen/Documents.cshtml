@model IEnumerable<CitizenDocument>
@{ ViewData["Title"] = "Documents"; }
<div class="page-header"><h1>My Documents</h1><p>Upload and manage verification documents</p></div>
<div class="row g-4">
    <div class="col-lg-4">
        <div class="table-card" style="padding:28px;">
            <h6 style="font-weight:700;margin-bottom:16px;"><i class="bi bi-cloud-upload me-2"></i>Upload Document</h6>
            <form method="post" asp-action="UploadDocument" asp-controller="Citizen" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="mb-3"><label class="form-label">Document Type</label><select name="documentType" class="form-select"><option>Identity</option><option>Qualification</option><option>Resume</option><option>Certificate</option></select></div>
                <div class="mb-3"><label class="form-label">File</label><input type="file" name="file" class="form-control" required /></div>
                <button type="submit" class="btn btn-accent w-100">Upload</button>
            </form>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="table-card">
            <div class="card-header-custom"><span>Uploaded Documents</span></div>
            <table class="table mb-0">
                <thead><tr><th>Document</th><th>Type</th><th>Uploaded</th><th>Status</th></tr></thead>
                <tbody>
                @foreach (var doc in Model)
                {
                    <tr>
                        <td><i class="bi bi-file-earmark me-2"></i>@doc.FileName</td>
                        <td>@doc.DocumentType</td>
                        <td>@doc.UploadedDate.ToString("MMM dd, yyyy")</td>
                        <td><span class="badge-status @(doc.VerificationStatus == "Verified" ? "badge-success" : doc.VerificationStatus == "Rejected" ? "badge-danger" : "badge-warning")">@doc.VerificationStatus</span></td>
                    </tr>
                }
                @if (!Model.Any()) { <tr><td colspan="4" class="text-center text-muted py-4">No documents uploaded yet.</td></tr> }
                </tbody>
            </table>
        </div>
    </div>
</div>
