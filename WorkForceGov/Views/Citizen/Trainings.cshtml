@model List<Training>
@using WorkForceGovProject.Models
@{
    ViewData["Title"] = "Training Programs";
    var myEnrollments = ViewBag.MyEnrollments as List<TrainingEnrollment> ?? new List<TrainingEnrollment>();
    var enrolledIds = ViewBag.EnrolledIds as HashSet<int> ?? new HashSet<int>();
}

<div class="page-header">
    <h1>Training Programs</h1>
    <p>Browse and enrol in available government training sessions</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-circle me-2"></i>@TempData["ErrorMessage"]</div>
}

@* ── My Enrollments ─────────────────────────────────────────────── *@
@if (myEnrollments.Any())
{
    <div class="table-card mb-4">
        <div class="card-header-custom">
            <span><i class="bi bi-bookmark-check me-2"></i>My Enrollments</span>
        </div>
        <table class="table mb-0">
            <thead>
                <tr><th>Training</th><th>Program</th><th>Dates</th><th>Enrolled On</th><th>Status</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var e in myEnrollments)
                {
                    <tr>
                        <td><strong>@e.Training?.Title</strong></td>
                        <td>@e.Training?.Program?.ProgramName</td>
                        <td style="font-size:.82rem;">
                            @e.Training?.StartDate.ToString("MMM dd, yyyy") –
                            @e.Training?.EndDate.ToString("MMM dd, yyyy")
                        </td>
                        <td style="font-size:.82rem;">@e.EnrolledDate.ToString("MMM dd, yyyy")</td>
                        <td>
                            <span class="badge-status @(e.Status == "Enrolled" ? "badge-info" : e.Status == "Completed" ? "badge-success" : "badge-secondary")">
                                @e.Status
                            </span>
                        </td>
                        <td>
                            @if (e.Status == "Enrolled")
                            {
                                <form method="post" asp-action="Unenroll" asp-route-trainingId="@e.TrainingId"
                                      onsubmit="return confirm('Are you sure you want to unenrol?');">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-x-circle me-1"></i>Unenrol
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@* ── Available Trainings ─────────────────────────────────────────── *@
<div class="table-card">
    <div class="card-header-custom">
        <span><i class="bi bi-journal-bookmark me-2"></i>Available Trainings</span>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-calendar-x" style="font-size:2rem;"></i>
            <p class="mt-2">No active training sessions are available right now.</p>
        </div>
    }
    else
    {
        <div class="row g-3" style="padding:20px;">
            @foreach (var t in Model)
            {
                bool enrolled = enrolledIds.Contains(t.Id);
                <div class="col-md-6 col-xl-4">
                    <div style="border:1px solid @(enrolled ? "#bbf7d0" : "#e2e8f0");border-radius:12px;padding:20px;
                        background:@(enrolled ? "#f0fdf4" : "#fafbfc");height:100%;display:flex;flex-direction:column;gap:10px;">

                        <div style="display:flex;align-items:flex-start;gap:10px;">
                            <div style="background:@(enrolled ? "#dcfce7" : "#dbeafe");color:@(enrolled ? "#16a34a" : "#2563eb");
                                border-radius:8px;width:38px;height:38px;flex-shrink:0;
                                display:flex;align-items:center;justify-content:center;">
                                <i class="bi bi-@(enrolled ? "check2-circle" : "journal-text")"></i>
                            </div>
                            <div>
                                <div style="font-weight:700;font-size:.95rem;">@t.Title</div>
                                <div style="font-size:.78rem;color:#94a3b8;">@t.Program?.ProgramName</div>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(t.Description))
                        {
                            <p style="font-size:.82rem;color:#64748b;margin:0;">@t.Description</p>
                        }

                        <div style="font-size:.78rem;color:#64748b;">
                            <i class="bi bi-calendar-range me-1"></i>
                            @t.StartDate.ToString("MMM dd") – @t.EndDate.ToString("MMM dd, yyyy")
                        </div>

                        <div style="margin-top:auto;">
                            @if (enrolled)
                            {
                                <span class="badge-status badge-success" style="font-size:.78rem;">
                                    <i class="bi bi-check-circle me-1"></i>Enrolled
                                </span>
                            }
                            else
                            {
                                <form method="post" asp-action="Enroll" asp-route-trainingId="@t.Id">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-accent btn-sm" style="width:100%;">
                                        <i class="bi bi-plus-circle me-1"></i>Enrol Now
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
