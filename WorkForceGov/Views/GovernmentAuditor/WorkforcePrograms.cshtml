@model IEnumerable<EmploymentProgram>
@{ ViewData["Title"] = "Workforce Programs"; }
<div class="page-header"><h1>Workforce Programs Review</h1></div>
<div class="table-card"><table class="table mb-0"><thead><tr><th>Program</th><th>Type</th><th>Budget</th><th>Start</th><th>End</th><th>Status</th></tr></thead><tbody>
@foreach(var p in Model){<tr><td><strong>@p.ProgramName</strong></td><td>@p.ProgramType</td><td style="font-weight:700;">$@p.TotalBudget.ToString("N0")</td><td>@p.StartDate.ToString("MMM dd, yyyy")</td><td>@p.EndDate?.ToString("MMM dd, yyyy")</td><td><span class="badge-status @(p.Status=="Active"?"badge-success":"badge-secondary")">@p.Status</span></td></tr>}
</tbody></table></div>
