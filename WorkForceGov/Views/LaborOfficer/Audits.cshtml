@model IEnumerable<Audit>
@{ ViewData["Title"] = "Audits"; }
<div class="page-header"><h1>Audit Records</h1></div>
<div class="table-card"><table class="table mb-0"><thead><tr><th>Scope</th><th>Findings</th><th>Date</th><th>Status</th></tr></thead><tbody>
@foreach(var a in Model){<tr><td>@a.Scope</td><td>@a.Findings</td><td>@a.Date.ToString("MMM dd")</td><td><span class="badge-status @(a.Status=="Completed"?"badge-success":a.Status=="Open"?"badge-warning":"badge-info")">@a.Status</span></td></tr>}
</tbody></table></div>
