@model LoginViewModel
@{ ViewData["Title"] = "Login"; }

<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#0f172a,#1e3a5f);padding:80px 16px 40px;">
    <div style="width:100%;max-width:420px;">
        <div style="text-align:center;margin-bottom:32px;">
            <div style="width:56px;height:56px;border-radius:16px;background:linear-gradient(135deg,#0ea5e9,#6366f1);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:1.5rem;color:white;">
                <i class="bi bi-building-gear"></i>
            </div>
            <h2 style="font-family:'Space Grotesk';font-weight:700;color:white;margin-bottom:4px;">Welcome Back</h2>
            <p style="color:#94a3b8;font-size:.9rem;">Sign in to your WorkForceGov account</p>
        </div>
        <div style="background:white;border-radius:20px;padding:36px;box-shadow:0 20px 60px rgba(0,0,0,.3);">
            <form method="post" asp-action="Login" asp-controller="Account">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <input type="email" name="Email" class="form-control" placeholder="you@example.com" required />
                </div>
                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <input type="password" name="Password" class="form-control" placeholder="Enter password" required />
                </div>
                <button type="submit" class="btn btn-accent w-100" style="padding:12px;">Sign In</button>
            </form>
            <p style="text-align:center;margin-top:20px;font-size:.85rem;color:#64748b;">
                Don't have an account? <a href="/Account/Register" style="color:#0ea5e9;font-weight:600;text-decoration:none;">Register</a>
            </p>
        </div>
        <div style="text-align:center;margin-top:24px;color:#475569;font-size:.75rem;">
            <strong>Test Logins:</strong> john.citizen@@gov.local · jane.employer@@company.com · admin@@gov.local<br/>Password: password123
        </div>
    </div>
</div>
