@{
    ViewData["Title"] = "Create Program";
}
<div class="page-header"><h1>Create Employment Program</h1></div>
<div class="row">
    <div class="col-lg-7">
        <div class="table-card" style="padding:32px;">
            <form method="post" asp-action="CreateProgram" asp-controller="ProgramManager">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-12"><label class="form-label">Program Name</label><input name="ProgramName" class="form-control" required /></div>
                    <div class="col-12"><label class="form-label">Description</label><textarea name="Description" class="form-control" rows="3"></textarea></div>
                    <div class="col-md-6"><label class="form-label">Type</label><select name="ProgramType" class="form-select"><option>Training</option><option>Subsidy</option><option>Cash</option></select></div>
                    <div class="col-md-6"><label class="form-label">Budget ($)</label><input type="number" name="TotalBudget" class="form-control" step="0.01" min="0" required placeholder="e.g. 50000" /></div>
                    <div class="col-md-6"><label class="form-label">Start Date</label><input type="date" name="StartDate" class="form-control" required /></div>
                    <div class="col-md-6"><label class="form-label">End Date</label><input type="date" name="EndDate" class="form-control" /></div>
                </div>
                <button type="submit" class="btn btn-accent mt-4">Create Program</button>
            </form>
        </div>
    </div>
</div>
