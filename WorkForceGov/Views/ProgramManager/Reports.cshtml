@model IEnumerable<Report>
@{ ViewData["Title"] = "Program Reports"; }

<div class="page-header"><h1><i class="bi bi-bar-chart me-2"></i>Program Reports</h1></div>

@if(TempData["SuccessMessage"] != null){<div class="alert alert-success alert-dismissible"><button type="button" class="btn-close" data-bs-dismiss="alert"></button>@TempData["SuccessMessage"]</div>}
@if(TempData["ErrorMessage"] != null){<div class="alert alert-danger alert-dismissible"><button type="button" class="btn-close" data-bs-dismiss="alert"></button>@TempData["ErrorMessage"]</div>}

<div class="row g-4">
  <!-- Generate Report Form -->
  <div class="col-lg-4">
    <div class="table-card" style="padding:28px;">
      <h6 style="font-weight:700;margin-bottom:16px;"><i class="bi bi-plus-square me-2"></i>Generate New Report</h6>
      <form method="post" asp-action="GenerateReport" asp-controller="ProgramManager">
        @Html.AntiForgeryToken()
        <div class="mb-3">
          <label class="form-label fw-semibold">Report Name</label>
          <input name="reportName" class="form-control" required placeholder="e.g. Q1 2026 Summary" />
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Report Type</label>
          <select name="reportType" class="form-select" required>
            <option value="">-- Select Type --</option>
            <option value="Training">Training</option>
            <option value="Budget">Budget</option>
            <option value="Performance">Performance</option>
            <option value="Beneficiary">Beneficiary</option>
            <option value="Resource">Resource</option>
          </select>
        </div>
        <button type="submit" class="btn btn-accent w-100"><i class="bi bi-play-circle me-2"></i>Generate Report</button>
      </form>
    </div>
  </div>

  <!-- Reports Table -->
  <div class="col-lg-8">
    <div class="table-card">
      <div class="card-header-custom"><span>Generated Reports</span></div>
      <table class="table mb-0">
        <thead><tr><th>Report Name</th><th>Type</th><th>Generated</th></tr></thead>
        <tbody>
        @foreach(var r in Model){
          <tr>
            <td><strong>@r.ReportName</strong></td>
            <td><span class="badge-status badge-info">@r.ReportType</span></td>
            <td>@r.GeneratedDate.ToString("MMM dd, yyyy HH:mm")</td>
          </tr>}
        @if(!Model.Any()){
          <tr><td colspan="3" class="text-center text-muted py-5">
            <i class="bi bi-bar-chart" style="font-size:2rem;display:block;margin-bottom:8px;"></i>
            No reports yet. Generate your first report.
          </td></tr>}
        </tbody>
      </table>
    </div>
  </div>
</div>
