@model IEnumerable<EmploymentProgram>
@{ ViewData["Title"] = "Program Management"; }
<div class="page-header" style="display:flex;justify-content:space-between;align-items:center;">
    <div><h1>Program Management</h1></div>
    <a href="/ProgramManager/CreateProgram" class="btn btn-accent"><i class="bi bi-plus-circle me-1"></i>Create Program</a>
</div>
<div class="table-card"><table class="table mb-0"><thead><tr><th>Program</th><th>Type</th><th>Budget</th><th>Duration</th><th>Status</th><th>Actions</th></tr></thead><tbody>
@foreach(var p in Model){<tr><td><strong>@p.ProgramName</strong><br/><span style="font-size:.75rem;color:#64748b;">@p.Description?.Substring(0, Math.Min(50, p.Description?.Length ?? 0))...</span></td><td>@p.ProgramType</td><td style="font-weight:700;">$@p.TotalBudget.ToString("N0")</td><td style="font-size:.8rem;">@p.StartDate.ToString("MMM dd") - @p.EndDate?.ToString("MMM dd, yyyy")</td><td><span class="badge-status @(p.Status=="Active"?"badge-success":"badge-secondary")">@p.Status</span></td><td>
    <a href="/ProgramManager/EditProgram/@p.Id" class="btn btn-sm btn-outline-primary" style="border-radius:8px;font-size:.75rem;">Edit</a>
    <form method="post" asp-action="DeleteProgram" asp-route-id="@p.Id" style="display:inline;">@Html.AntiForgeryToken()<button class="btn btn-sm btn-outline-danger" style="border-radius:8px;font-size:.75rem;">Delete</button></form>
</td></tr>}
</tbody></table></div>
