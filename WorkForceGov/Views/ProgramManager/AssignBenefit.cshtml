@{
    ViewData["Title"] = "Assign Benefit";
    var programs = ViewBag.Programs as IEnumerable<WorkForceGovProject.Models.EmploymentProgram> ?? new List<WorkForceGovProject.Models.EmploymentProgram>();
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div><h1><i class="bi bi-person-plus me-2"></i>Assign Benefit to Citizen</h1><p>Directly assign a program benefit to a citizen</p></div>
    <a href="/ProgramManager/Benefits" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="row">
    <div class="col-lg-6">
        <div class="table-card" style="padding:32px;">
            <form method="post" asp-action="AssignBenefit" asp-controller="ProgramManager">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label fw-semibold">Citizen ID <span class="text-danger">*</span></label>
                        <input type="number" name="citizenId" class="form-control" placeholder="Enter citizen ID" required min="1" />
                        <small class="text-muted">You can find the citizen ID in Admin → Manage Users</small>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Program <span class="text-danger">*</span></label>
                        <select name="programId" class="form-select" required>
                            <option value="">— Select a program —</option>
                            @foreach (var p in programs.Where(p => p.Status == "Active"))
                            {
                                <option value="@p.Id">@p.ProgramName (@p.ProgramType)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Benefit Type <span class="text-danger">*</span></label>
                        <select name="benefitType" class="form-select" required>
                            <option value="Cash Transfer">Cash Transfer</option>
                            <option value="Subsidy">Subsidy</option>
                            <option value="Training Voucher">Training Voucher</option>
                            <option value="Housing Allowance">Housing Allowance</option>
                            <option value="Medical Allowance">Medical Allowance</option>
                            <option value="General">General</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Amount ($) <span class="text-danger">*</span></label>
                        <input type="number" name="amount" class="form-control" placeholder="e.g. 500.00" step="0.01" min="0" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Description / Notes</label>
                        <textarea name="description" class="form-control" rows="3" placeholder="Optional notes about this benefit..."></textarea>
                    </div>
                </div>
                <button type="submit" class="btn btn-accent mt-4">
                    <i class="bi bi-send me-2"></i>Assign Benefit
                </button>
            </form>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="table-card" style="padding:24px;">
            <h6 style="font-weight:700;margin-bottom:12px;"><i class="bi bi-info-circle me-2 text-primary"></i>Active Programs</h6>
            @foreach (var p in programs.Where(p => p.Status == "Active"))
            {
                <div style="border:1px solid #e2e8f0;border-radius:8px;padding:12px;margin-bottom:10px;">
                    <div style="font-weight:600;font-size:.9rem;">@p.ProgramName</div>
                    <div style="font-size:.78rem;color:#64748b;">@p.ProgramType • Budget: $@p.TotalBudget.ToString("N0")</div>
                    @if (!string.IsNullOrEmpty(p.Description))
                    {
                        <div style="font-size:.78rem;color:#94a3b8;margin-top:4px;">@p.Description</div>
                    }
                </div>
            }
            @if (!programs.Any(p => p.Status == "Active"))
            {
                <p class="text-muted">No active programs available. Create a program first.</p>
            }
        </div>
    </div>
</div>
