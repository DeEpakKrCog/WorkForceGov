@model IEnumerable<EmploymentProgram>
@{ ViewData["Title"] = "Resource Management"; }
<div class="page-header"><h1>Resource Management</h1></div>
<div class="table-card"><table class="table mb-0"><thead><tr><th>Program</th><th>Budget</th><th>Status</th></tr></thead><tbody>
@foreach(var p in Model){<tr><td><strong>@p.ProgramName</strong></td><td>$@p.TotalBudget.ToString("N0")</td><td><span class="badge-status @(p.Status=="Active"?"badge-success":"badge-secondary")">@p.Status</span></td></tr>}
</tbody></table></div>
