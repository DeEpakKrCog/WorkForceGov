@model ErrorViewModel
@{ ViewData["Title"] = "Error"; }
<div class="text-center py-5">
    <i class="bi bi-exclamation-triangle fs-1 text-danger"></i>
    <h2 class="mt-3">An error occurred</h2>
    <p class="text-muted">Something went wrong while processing your request.</p>
    @if(Model?.ShowRequestId ?? false){<p class="text-muted small">Request ID: @Model.RequestId</p>}
    <a href="/" class="btn btn-accent mt-3">Go Home</a>
</div>
