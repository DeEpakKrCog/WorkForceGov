@using Microsoft.AspNetCore.Http
@{
    var userId = Context.Session.GetInt32("UserId");
    var userName = Context.Session.GetString("UserName") ?? "";
    var userRole = Context.Session.GetString("UserRole") ?? "";
    var isLoggedIn = userId != null;

    string GetRoleColor() => userRole switch {
        "Citizen" => "#0ea5e9",
        "Employer" => "#8b5cf6",
        "SystemAdmin" => "#ef4444",
        "LaborOfficer" => "#f59e0b",
        "ComplianceOfficer" => "#10b981",
        "GovernmentAuditor" => "#6366f1",
        "ProgramManager" => "#ec4899",
        _ => "#64748b"
    };

    string GetRoleLabel() => userRole switch {
        "SystemAdmin" => "Administrator",
        "LaborOfficer" => "Labor Officer",
        "ComplianceOfficer" => "Compliance Officer",
        "GovernmentAuditor" => "Government Auditor",
        "ProgramManager" => "Program Manager",
        _ => userRole
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — WorkForceGov</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --accent: @GetRoleColor();
            --bg: #f0f2f5;
            --sidebar-bg: #0f172a;
            --sidebar-w: 260px;
            --nav-h: 60px;
            --card-radius: 14px;
        }
        * { box-sizing: border-box; }
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            margin: 0;
            color: #1e293b;
        }

        /* ─── TOP NAV ─── */
        .topnav {
            position: fixed; top: 0; left: 0; right: 0;
            height: var(--nav-h); z-index: 1030;
            background: #ffffff;
            border-bottom: 1px solid #e2e8f0;
            display: flex; align-items: center;
            padding: 0 24px;
            box-shadow: 0 1px 3px rgba(0,0,0,.06);
        }
        .topnav .brand {
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 700; font-size: 1.25rem;
            color: #0f172a; text-decoration: none;
            display: flex; align-items: center; gap: 10px;
        }
        .topnav .brand-icon {
            width: 36px; height: 36px; border-radius: 10px;
            background: linear-gradient(135deg, #0ea5e9, #6366f1);
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: 1.1rem;
        }
        .topnav .nav-end {
            margin-left: auto; display: flex; align-items: center; gap: 16px;
        }
        .role-badge {
            font-size: .72rem; font-weight: 600; text-transform: uppercase;
            letter-spacing: .5px; padding: 4px 12px; border-radius: 20px;
            color: white; background: var(--accent);
        }
        .user-avatar {
            width: 36px; height: 36px; border-radius: 50%;
            background: var(--accent); color: white;
            display: flex; align-items: center; justify-content: center;
            font-weight: 600; font-size: .85rem;
        }

        /* ─── SIDEBAR ─── */
        .sidebar {
            position: fixed; top: var(--nav-h); left: 0; bottom: 0;
            width: var(--sidebar-w); z-index: 1020;
            background: var(--sidebar-bg);
            overflow-y: auto; padding: 20px 0;
            transition: transform .3s ease;
        }
        .sidebar-section {
            padding: 0 16px; margin-bottom: 8px;
        }
        .sidebar-label {
            font-size: .65rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 1.5px;
            color: #475569; padding: 12px 16px 6px;
        }
        .sidebar .nav-link {
            display: flex; align-items: center; gap: 12px;
            padding: 10px 16px; margin: 2px 12px;
            border-radius: 10px; color: #94a3b8;
            font-size: .875rem; font-weight: 500;
            text-decoration: none; transition: all .15s;
        }
        .sidebar .nav-link:hover {
            background: rgba(255,255,255,.08); color: #e2e8f0;
        }
        .sidebar .nav-link.active {
            background: var(--accent); color: white;
            box-shadow: 0 4px 12px rgba(0,0,0,.2);
        }
        .sidebar .nav-link i { font-size: 1.1rem; width: 22px; text-align: center; }

        /* ─── MAIN ─── */
        .main-content {
            margin-left: var(--sidebar-w);
            margin-top: var(--nav-h);
            padding: 28px 32px;
            min-height: calc(100vh - var(--nav-h));
        }
        .main-public {
            margin-left: 0;
            margin-top: var(--nav-h);
            padding: 0;
        }

        /* ─── CARDS ─── */
        .stat-card {
            background: white; border-radius: var(--card-radius);
            padding: 22px 24px;
            box-shadow: 0 1px 3px rgba(0,0,0,.05);
            border: 1px solid #e2e8f0;
            transition: transform .15s, box-shadow .15s;
        }
        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0,0,0,.08);
        }
        .stat-card .stat-icon {
            width: 48px; height: 48px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem; margin-bottom: 16px;
        }
        .stat-card .stat-value {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.75rem; font-weight: 700;
            line-height: 1;
        }
        .stat-card .stat-label {
            font-size: .8rem; color: #64748b;
            margin-top: 4px; font-weight: 500;
        }

        /* ─── TABLE ─── */
        .table-card {
            background: white; border-radius: var(--card-radius);
            box-shadow: 0 1px 3px rgba(0,0,0,.05);
            border: 1px solid #e2e8f0; overflow: hidden;
        }
        .table-card .card-header-custom {
            padding: 18px 24px; border-bottom: 1px solid #e2e8f0;
            font-weight: 600; font-size: .95rem;
            display: flex; align-items: center; justify-content: space-between;
        }
        .table-card table { margin: 0; }
        .table-card th {
            font-size: .72rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: .5px;
            color: #64748b; background: #f8fafc;
            padding: 12px 16px !important; border: none !important;
        }
        .table-card td {
            padding: 14px 16px !important; vertical-align: middle;
            border-color: #f1f5f9 !important; font-size: .875rem;
        }

        /* ─── BADGES ─── */
        .badge-status {
            font-size: .72rem; font-weight: 600; padding: 5px 12px;
            border-radius: 20px;
        }
        .badge-success { background: #dcfce7; color: #166534; }
        .badge-warning { background: #fef3c7; color: #92400e; }
        .badge-danger { background: #fee2e2; color: #991b1b; }
        .badge-info { background: #dbeafe; color: #1e40af; }
        .badge-secondary { background: #f1f5f9; color: #475569; }

        /* ─── FORMS ─── */
        .form-control, .form-select {
            border-radius: 10px; border: 1.5px solid #e2e8f0;
            padding: 10px 16px; font-size: .875rem;
            transition: border-color .15s, box-shadow .15s;
        }
        .form-control:focus, .form-select:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 15%, transparent);
        }
        .form-label {
            font-weight: 600; font-size: .8rem;
            color: #374151; margin-bottom: 6px;
        }

        /* ─── BUTTONS ─── */
        .btn-accent {
            background: var(--accent); color: white;
            border: none; border-radius: 10px;
            padding: 10px 24px; font-weight: 600;
            font-size: .875rem; transition: all .15s;
        }
        .btn-accent:hover {
            filter: brightness(1.1); color: white;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px color-mix(in srgb, var(--accent) 40%, transparent);
        }

        /* ─── PAGE HEADER ─── */
        .page-header {
            margin-bottom: 28px;
        }
        .page-header h1 {
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 700; font-size: 1.6rem;
            margin: 0;
        }
        .page-header p {
            color: #64748b; font-size: .9rem; margin: 4px 0 0;
        }

        /* ─── ALERTS ─── */
        .alert {
            border-radius: 12px; border: none;
            font-size: .875rem; font-weight: 500;
        }

        /* ─── RESPONSIVE ─── */
        @@media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.show { transform: translateX(0); }
            .main-content { margin-left: 0; padding: 20px 16px; }
        }
    </style>
</head>
<body>
    <!-- TOP NAV -->
    <nav class="topnav">
        <a class="brand" href="/">
            <div class="brand-icon"><i class="bi bi-building-gear"></i></div>
            WorkForceGov
        </a>
        @if (!isLoggedIn)
        {
            <div class="nav-end">
                <a href="/Account/Login" class="btn btn-sm btn-outline-dark" style="border-radius:10px;">Login</a>
                <a href="/Account/Register" class="btn btn-sm btn-accent">Register</a>
            </div>
        }
        else
        {
            <div class="nav-end">
                <span class="role-badge">@GetRoleLabel()</span>
                <div class="dropdown">
                    <button class="btn p-0 border-0 bg-transparent" data-bs-toggle="dropdown">
                        <div class="user-avatar">@(userName.Length > 0 ? userName[0].ToString().ToUpper() : "U")</div>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="border-radius:12px;border:1px solid #e2e8f0;margin-top:8px;">
                        <li class="px-3 py-2"><strong class="small">@userName</strong><br/><span class="text-muted" style="font-size:.75rem;">@Context.Session.GetString("UserEmail")</span></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item small" href="/Account/Logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                    </ul>
                </div>
                <button class="btn d-md-none p-1" onclick="document.querySelector('.sidebar').classList.toggle('show')">
                    <i class="bi bi-list fs-4"></i>
                </button>
            </div>
        }
    </nav>

    @if (isLoggedIn)
    {
        <!-- SIDEBAR -->
        <nav class="sidebar">
            <div class="sidebar-label">Navigation</div>

            @if (userRole == "Citizen")
            {
                <a class="nav-link" href="/Citizen/Dashboard"><i class="bi bi-grid-1x2"></i> Dashboard</a>
                <a class="nav-link" href="/Citizen/JobSearch"><i class="bi bi-search"></i> Job Search</a>
                <a class="nav-link" href="/Citizen/JobApplications"><i class="bi bi-file-earmark-text"></i> My Applications</a>
                <a class="nav-link" href="/Citizen/Trainings"><i class="bi bi-journal-bookmark"></i> Trainings</a>
                <a class="nav-link" href="/Citizen/Documents"><i class="bi bi-folder2-open"></i> Documents</a>
                <a class="nav-link" href="/Citizen/Benefits"><i class="bi bi-gift"></i> Benefits</a>
                <a class="nav-link" href="/Citizen/Profile"><i class="bi bi-person-gear"></i> Profile</a>
                <a class="nav-link" href="/Citizen/Notifications"><i class="bi bi-bell"></i> Notifications</a>
            }
            else if (userRole == "Employer")
            {
                <a class="nav-link" href="/Employer/Dashboard"><i class="bi bi-grid-1x2"></i> Dashboard</a>
                <a class="nav-link" href="/Employer/CreateJob"><i class="bi bi-plus-circle"></i> Post Job</a>
                <a class="nav-link" href="/Employer/ManageJobs"><i class="bi bi-briefcase"></i> Manage Jobs</a>
                <a class="nav-link" href="/Employer/Applications"><i class="bi bi-people"></i> Applications</a>
                <a class="nav-link" href="/Employer/Profile"><i class="bi bi-building"></i> Company Profile</a>
                <a class="nav-link" href="/Employer/Notifications"><i class="bi bi-bell"></i> Notifications</a>
            }
            else if (userRole == "SystemAdmin")
            {
                <a class="nav-link" href="/Admin/Dashboard"><i class="bi bi-grid-1x2"></i> Dashboard</a>
                <a class="nav-link" href="/Admin/ManageUsers"><i class="bi bi-people-fill"></i> Manage Users</a>
                <a class="nav-link" href="/Admin/Reports"><i class="bi bi-file-bar-graph"></i> Reports</a>
                <a class="nav-link" href="/Admin/SystemMonitoring"><i class="bi bi-activity"></i> System Logs</a>
            }
            else if (userRole == "LaborOfficer")
            {
                <a class="nav-link" href="/LaborOfficer/Dashboard"><i class="bi bi-grid-1x2"></i> Dashboard</a>
                <a class="nav-link" href="/LaborOfficer/DocumentVerifications"><i class="bi bi-file-check"></i> Verify Documents</a>
                <a class="nav-link" href="/LaborOfficer/Applications"><i class="bi bi-file-earmark-text"></i> Applications</a>
                <a class="nav-link" href="/LaborOfficer/Compliance"><i class="bi bi-shield-check"></i> Compliance</a>
                <a class="nav-link" href="/LaborOfficer/Audits"><i class="bi bi-clipboard-data"></i> Audits</a>
                <a class="nav-link" href="/LaborOfficer/Reports"><i class="bi bi-file-bar-graph"></i> Reports</a>
            }
            else if (userRole == "ComplianceOfficer")
            {
                <a class="nav-link" href="/ComplianceOfficer/Dashboard"><i class="bi bi-grid-1x2"></i> Dashboard</a>
                <a class="nav-link" href="/ComplianceOfficer/EmployerReview"><i class="bi bi-building-check"></i> Employer Review</a>
                <a class="nav-link" href="/ComplianceOfficer/InvestigateComplaint"><i class="bi bi-exclamation-triangle"></i> Complaints</a>
                <a class="nav-link" href="/ComplianceOfficer/ComplianceReports"><i class="bi bi-file-bar-graph"></i> Reports</a>
            }
            else if (userRole == "GovernmentAuditor")
            {
                <a class="nav-link" href="/GovernmentAuditor/Dashboard"><i class="bi bi-grid-1x2"></i> Dashboard</a>
                <a class="nav-link" href="/GovernmentAuditor/ComplianceMonitoring"><i class="bi bi-shield-check"></i> Compliance</a>
                <a class="nav-link" href="/GovernmentAuditor/WorkforcePrograms"><i class="bi bi-diagram-3"></i> Programs</a>
                <a class="nav-link" href="/GovernmentAuditor/AuditReports"><i class="bi bi-file-bar-graph"></i> Audit Reports</a>
                <a class="nav-link" href="/GovernmentAuditor/AlertsAndNotifications"><i class="bi bi-bell"></i> Alerts</a>
            }
            else if (userRole == "ProgramManager")
            {
                <a class="nav-link" href="/ProgramManager/Dashboard"><i class="bi bi-grid-1x2"></i> Dashboard</a>
                <a class="nav-link" href="/ProgramManager/ProgramManagement"><i class="bi bi-kanban"></i> Programs</a>
                <a class="nav-link" href="/ProgramManager/Benefits"><i class="bi bi-gift"></i> Benefits</a>
                <a class="nav-link" href="/ProgramManager/BudgetMonitoring"><i class="bi bi-wallet2"></i> Budget</a>
                <a class="nav-link" href="/ProgramManager/TrainingManagement"><i class="bi bi-mortarboard"></i> Training</a>
                <a class="nav-link" href="/ProgramManager/ResourceManagement"><i class="bi bi-box-seam"></i> Resources</a>
                <a class="nav-link" href="/ProgramManager/PerformanceTracking"><i class="bi bi-graph-up"></i> Performance</a>
                <a class="nav-link" href="/ProgramManager/Reports"><i class="bi bi-file-bar-graph"></i> Reports</a>
            }

            <div style="margin-top:auto; padding: 16px;">
                <hr style="border-color:#1e293b;"/>
                <a class="nav-link text-danger" href="/Account/Logout"><i class="bi bi-box-arrow-left"></i> Logout</a>
            </div>
        </nav>

        <main class="main-content">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    }
    else
    {
        <main class="main-public">
            @if (TempData["SuccessMessage"] != null || TempData["ErrorMessage"] != null)
            {
                <div style="max-width:600px;margin:80px auto 0;padding:0 16px;">
                    @if (TempData["SuccessMessage"] != null) { <div class="alert alert-success">@TempData["SuccessMessage"]</div> }
                    @if (TempData["ErrorMessage"] != null) { <div class="alert alert-danger">@TempData["ErrorMessage"]</div> }
                </div>
            }
            @RenderBody()
        </main>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Active sidebar link
        document.querySelectorAll('.sidebar .nav-link').forEach(link => {
            if (link.getAttribute('href') === window.location.pathname) {
                link.classList.add('active');
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
