      "get": {
        "tags": [
          "Dashboard"
        ],
        "summary": "Get Labor Officer dashboard",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/labor-officer/documents/citizen/pending": {
      "get": {
        "tags": [
          "Document Verification"
        ],
        "summary": "Get pending citizen documents",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/labor-officer/documents/citizen/{id}/verify": {
      "put": {
        "tags": [
          "Document Verification"
        ],
        "summary": "Verify a citizen document",
