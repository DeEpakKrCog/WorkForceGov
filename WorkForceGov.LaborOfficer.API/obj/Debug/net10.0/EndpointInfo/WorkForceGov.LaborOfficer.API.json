          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/labor-officer/documents/citizen/{id}/reject": {
      "put": {
        "tags": [
          "Document Verification"
        ],
        "summary": "Reject a citizen document",
